          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=10;shadow=1;"
