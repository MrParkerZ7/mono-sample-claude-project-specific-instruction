<mxfile host="app.diagrams.net">
  <diagram name="Data Flow" id="data-flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Data Flow - Function Export &amp; Build Pipeline"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#232F3E;"
          vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- Section 1: Function Export Flow -->
        <mxCell id="section-1" value="Function Export Flow"
          style="swimlane;startSize=0;strokeWidth=2;labelBorderColor=none;textShadow=1;labelBackgroundColor=default;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;shadow=1;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="1200" height="280" as="geometry"/>
        </mxCell>

        <!-- sample-common source -->
        <mxCell id="common-src" value="&lt;b&gt;@lerna-ts/sample-common&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:10px'&gt;src/index.ts&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style='font-size:9px;font-family:monospace'&gt;export const sampleFunction&lt;br&gt;= (msg: string): string =&gt;&lt;br&gt;`SampleFunction Print :: ${msg}`&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontColor=#000000;verticalAlign=middle;fontSize=11;shadow=1;"
          vertex="1" parent="1">
          <mxGeometry x="120" y="140" width="240" height="120" as="geometry"/>
        </mxCell>

        <!-- sample-service source -->
