                <!-- Account Activation 3 -->
                <mxCell id="act-account-3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1;" vertex="1" parent="1">
                    <mxGeometry x="715" y="680" width="10" height="50" as="geometry"/>
                </mxCell>

                <!-- 11. Hold Confirmed -->
                <mxCell id="msg-11" value="11. HoldRef: HOLD-20240115-001" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=open;endFill=0;dashed=1;fontSize=9;labelBackgroundColor=#ffffff;shadow=1;textShadow=1;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
