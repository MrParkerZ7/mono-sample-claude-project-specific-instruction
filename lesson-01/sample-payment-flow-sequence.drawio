                </mxCell>

                <!-- 3. BFF validates and transforms -->
                <mxCell id="msg-3" value="3. Validate &amp; Transform Request" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;fontSize=9;labelBackgroundColor=#ffffff;shadow=1;textShadow=1;" edge="1" parent="1">
