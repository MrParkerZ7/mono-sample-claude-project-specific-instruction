                <!-- ISO20022 Note -->
                <mxCell id="note-iso" value="ISO 20022 Message:&#xa;• pacs.008 Credit Transfer&#xa;• MsgId: unique ref&#xa;• Amount: 1000 THB&#xa;• Debtor: Our Bank&#xa;• Creditor: BBL" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingTop=5;spacingLeft=5;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=8;shadow=1;textShadow=1;" vertex="1" parent="1">
