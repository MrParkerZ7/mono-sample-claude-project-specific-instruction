                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="880" y="610" as="sourcePoint"/>
                        <mxPoint x="560" y="610" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- ========== PHASE 4: DEBIT SOURCE ========== -->
                <mxCell id="phase4" value="Phase 4: Debit Source Account (Hold)" style="text;html=1;fontSize=12;fontStyle=3;align=left;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;shadow=1;textShadow=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="640" width="220" height="25" as="geometry"/>
                </mxCell>

                <!-- 10. Hold Amount -->
                <mxCell id="msg-10" value="10. holdAmount(fromAccount, 1000 THB)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;fontSize=9;labelBackgroundColor=#ffffff;shadow=1;textShadow=1;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
