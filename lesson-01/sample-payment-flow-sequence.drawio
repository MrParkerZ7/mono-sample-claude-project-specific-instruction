                    </mxGeometry>
                </mxCell>

                <!-- ITMX Activation -->
                <mxCell id="act-itmx-1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=1;" vertex="1" parent="1">
                    <mxGeometry x="1355" y="870" width="10" height="50" as="geometry"/>
                </mxCell>

                <!-- 15. Return Account Info -->
                <mxCell id="msg-15" value="15. Account: BBL xxx-xxxxx-x" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=open;endFill=0;dashed=1;fontSize=9;labelBackgroundColor=#ffffff;shadow=1;textShadow=1;" edge="1" parent="1">
