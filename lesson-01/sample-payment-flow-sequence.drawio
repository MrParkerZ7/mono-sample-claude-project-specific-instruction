                <!-- 19. Return ITMX Response -->
                <mxCell id="msg-19" value="19. ITMX Response: SUCCESS" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=open;endFill=0;dashed=1;fontSize=9;labelBackgroundColor=#ffffff;shadow=1;textShadow=1;" edge="1" parent="1">
