                <!-- 13. Resolve PromptPay -->
                <mxCell id="msg-13" value="13. resolvePromptPayId(0812345678)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=block;endFill=1;fontSize=9;labelBackgroundColor=#ffffff;shadow=1;textShadow=1;" edge="1" parent="1">
