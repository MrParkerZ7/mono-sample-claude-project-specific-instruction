                <!-- 12. Initiate Payment -->
                <mxCell id="msg-12" value="12. initiateITMXTransfer(paymentData)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=block;endFill=1;fontSize=9;labelBackgroundColor=#ffffff;shadow=1;textShadow=1;" edge="1" parent="1">
