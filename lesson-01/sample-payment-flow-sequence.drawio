                    <mxGeometry x="40" y="170" width="220" height="25" as="geometry"/>
                </mxCell>

                <!-- 1. Mobile to Gateway -->
                <mxCell id="msg-1" value="1. POST /api/v1/payments/transfer" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;fontSize=9;labelBackgroundColor=#ffffff;shadow=1;textShadow=1;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="100" y="210" as="sourcePoint"/>
                        <mxPoint x="250" y="210" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- Request Body Note -->
                <mxCell id="note-request" value="{&#xa;  &quot;fromAccount&quot;: &quot;xxx-x-xxxxx-x&quot;,&#xa;  &quot;toPromptPayId&quot;: &quot;0812345678&quot;,&#xa;  &quot;amount&quot;: 1000.00,&#xa;  &quot;currency&quot;: &quot;THB&quot;,&#xa;  &quot;note&quot;: &quot;ค่าอาหาร&quot;&#xa;}" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingTop=5;spacingLeft=5;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=8;fontFamily=Courier New;shadow=1;textShadow=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="220" width="160" height="100" as="geometry"/>
