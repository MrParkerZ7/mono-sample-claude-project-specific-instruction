                    <mxGeometry x="20" y="90" width="200" height="20" as="geometry"/>
                </mxCell>

                <mxCell id="legend-stack" value="• K8s Distribution: kubeadm / RKE2 / k3s&#xa;• CNI: Calico (Network Policies)&#xa;• Service Mesh: Istio&#xa;• Ingress: NGINX Ingress Controller&#xa;• Load Balancer: MetalLB (L2/BGP)&#xa;• Storage: Rook-Ceph / NFS&#xa;• Auth: Keycloak (OAuth2/OIDC)&#xa;• Secrets: HashiCorp Vault&#xa;• GitOps: ArgoCD + Argo Rollouts&#xa;• CI/CD: GitLab + GitLab Runners&#xa;• Registry: Harbor&#xa;• Monitoring: Prometheus + Grafana + Loki&#xa;• Tracing: Jaeger&#xa;• DB: PostgreSQL (Patroni HA)&#xa;• Cache: Redis Cluster&#xa;• Document: MongoDB Replica Set&#xa;• Search: Elasticsearch&#xa;• Object Storage: MinIO&#xa;• Message Queue: Kafka (Strimzi)" style="text;html=1;fontSize=9;align=left;spacing=2;shadow=1;textShadow=1;" vertex="1" parent="legend">
